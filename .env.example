# LLM Configuration (optional - auto-detects provider from API key)
# WOOGRAPH_LLM_PROVIDER=deepseek
# WOOGRAPH_LLM_MODEL=deepseek-chat
# WOOGRAPH_LLM_TEMPERATURE=0.0

# API Keys (set one - provider auto-detected)
# Priority order: DeepSeek > OpenAI > Anthropic > Gemini > Mistral
# DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# MISTRAL_API_KEY=...

# Generic override (takes precedence over provider-specific keys)
# WOOGRAPH_API_KEY=sk-...
